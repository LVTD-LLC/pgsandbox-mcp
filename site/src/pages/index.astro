---
import BaseLayout from '../layouts/BaseLayout.astro';

const lifecycle = [
  {
    title: 'Request',
    body: 'An agent asks for a task database with a purpose, owner, labels, and TTL.'
  },
  {
    title: 'Create',
    body: 'PGSandbox creates one database and one scoped login role through the admin profile.'
  },
  {
    title: 'Prove',
    body: 'Migrations, seeds, repro queries, and schema inspection run against real Postgres.'
  },
  {
    title: 'Remove',
    body: 'Explicit delete or TTL cleanup drops only resources recorded by PGSandbox metadata.'
  }
];

const safeguards = [
  ['Admin stays separate', 'Lifecycle metadata uses the admin connection. User SQL runs through the sandbox role.'],
  ['Secrets stay bounded', 'Diagnostics mask credentials. Connection strings only appear from credential-returning commands and tools.'],
  ['Deletion is tracked', 'Cleanup and delete paths require a metadata row for the selected profile before dropping resources.']
];

const tools = [
  ['create_database', 'Create an isolated database and scoped role for a task.'],
  ['run_sql', 'Execute SQL with optional readonly mode, timing, row caps, and truncation metadata.'],
  ['describe_schema', 'Inspect tables, columns, indexes, and extensions as structured data.'],
  ['get_connection_string', 'Return sandbox credentials and expiry details when an agent needs direct access.'],
  ['list_databases', 'List active sandboxes without dumping full connection strings.'],
  ['cleanup_expired', 'Delete expired resources, with dry-run support for inspection.'],
  ['delete_database', 'Remove a tracked sandbox database and role explicitly.']
];
---
<BaseLayout
  title="PGSandbox MCP - disposable Postgres for coding agents"
  description="PGSandbox MCP gives coding agents private Postgres databases for migrations, bug repros, seeded demos, and SQL validation."
>
  <main id="content">
    <section class="hero container">
      <div class="hero-copy">
        <p class="product-label">PGSandbox MCP</p>
        <h1>Give every agent task its own Postgres database.</h1>
        <p class="lede">
          A local MCP server for creating disposable databases, scoped roles, and cleanup metadata on Postgres you already control.
          Agents can validate SQL without touching shared development state.
        </p>
        <div class="actions" role="group" aria-label="Primary actions">
          <a class="button primary" href="#start">Install package</a>
          <a class="button subtle" href="/docs/">Read docs</a>
        </div>
        <dl class="client-list" aria-label="Supported MCP clients">
          <div>
            <dt>Clients</dt>
            <dd>Codex, Cursor, VS Code, Claude Desktop</dd>
          </div>
          <div>
            <dt>Runtime</dt>
            <dd>Node.js, stdio MCP, existing Postgres</dd>
          </div>
        </dl>
      </div>

      <aside class="hero-console" aria-label="Sandbox setup and lifecycle preview">
        <div class="console-head">
          <span class="status-dot" aria-hidden="true"></span>
          <span>new sandbox</span>
          <code>ttl 240m</code>
        </div>
        <div class="code-panel shell">
          <pre><code>npm install -g pgsandbox-mcp
pgsandbox-mcp setup \
  --client codex \
  --admin-url "$PGSANDBOX_ADMIN_DATABASE_URL"
pgsandbox-mcp doctor</code></pre>
        </div>
        <div class="sandbox-object" aria-label="Created sandbox example">
          <div>
            <span>database</span>
            <code>pgsandbox_migration_ab12</code>
          </div>
          <div>
            <span>role</span>
            <code>pgsandbox_role_ab12</code>
          </div>
          <div>
            <span>cleanup</span>
            <code>metadata tracked</code>
          </div>
        </div>
      </aside>
    </section>

    <section class="lifecycle-band" aria-label="Sandbox lifecycle">
      <div class="container lifecycle-grid">
        {lifecycle.map((item) => (
          <article class="lifecycle-step">
            <h2>{item.title}</h2>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section container proof-section">
      <div class="section-copy">
        <span class="section-label">why it exists</span>
        <h2>The safe database path should be the shortest path.</h2>
        <p>
          Agent tasks often need real database behavior to verify migrations, reproduce bugs, or inspect generated SQL.
          PGSandbox makes a fresh database cheaper than asking for shared credentials or skipping the check.
        </p>
      </div>
      <div class="proof-layout">
        <article class="proof-primary">
          <h3>Task state is isolated by default.</h3>
          <p>
            Each experiment gets one database, one login role, TTL metadata, and optional labels for the repo, branch, owner,
            or task. The admin connection handles lifecycle work only.
          </p>
        </article>
        <div class="safeguard-list">
          {safeguards.map(([title, body]) => (
            <article>
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="start" class="section install-section">
      <div class="container install-grid">
        <div class="install-copy">
          <span class="section-label">install</span>
          <h2>Register the MCP server with one admin URL.</h2>
          <p>
            Use npm, npx, or Homebrew. PGSandbox does not install Postgres and does not require Docker.
            It targets a reachable Postgres instance where your configured user can create databases and roles.
          </p>
          <a class="text-link" href="/docs/install/">Open the installation guide</a>
        </div>
        <div class="code-panel shell">
          <pre><code>export PGSANDBOX_ADMIN_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"
npm install -g pgsandbox-mcp
pgsandbox-mcp setup --client codex --admin-url "$PGSANDBOX_ADMIN_DATABASE_URL"
pgsandbox-mcp smoke-test</code></pre>
        </div>
      </div>
    </section>

    <section class="section container tools-section">
      <div class="tools-head">
        <div>
          <span class="section-label">tool contract</span>
          <h2>A narrow MCP surface for database proof.</h2>
        </div>
        <p>
          The v0 tools cover creation, credentials, SQL execution, schema inspection, listing, cleanup, and explicit deletion.
        </p>
      </div>
      <div class="tool-table" role="list">
        {tools.map(([name, body]) => (
          <article class="tool-row" role="listitem">
            <code>{name}</code>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="closing-band">
      <div class="container closing-inner">
        <div>
          <span class="section-label">local first</span>
          <h2>Keep database verification inside the agent loop.</h2>
          <p>
            Start with one Postgres admin connection, then add profiles for other hosts or versions when the workflow needs them.
          </p>
        </div>
        <div class="actions">
          <a class="button primary" href="/docs/install/">Install package</a>
          <a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">View repository</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(390px, 0.92fr);
    gap: 3.5rem;
    align-items: center;
    padding: 6.25rem 0 5rem;
  }

  .product-label {
    margin: 0 0 1rem;
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 760;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: 4.35rem;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .lede {
    max-width: 720px;
    margin: 1.25rem 0 0;
    color: var(--muted);
    font-size: 1.17rem;
    line-height: 1.72;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .client-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    max-width: 720px;
    margin: 2rem 0 0;
  }

  .client-list div {
    padding-top: 0.85rem;
    border-top: 1px solid var(--line);
  }

  .client-list dt {
    color: var(--ink);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .client-list dd {
    margin: 0.3rem 0 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.48;
  }

  .hero-console {
    min-width: 0;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-short);
  }

  .console-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0.55rem;
    align-items: center;
    padding: 0.25rem 0.1rem 0.95rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 760;
  }

  .console-head code {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .status-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: var(--success);
  }

  .sandbox-object {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .sandbox-object div {
    display: grid;
    grid-template-columns: 6.2rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    padding: 0.7rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--surface-muted);
  }

  .sandbox-object span {
    color: var(--quiet);
    font-size: 0.84rem;
    font-weight: 750;
  }

  .sandbox-object code {
    overflow-wrap: anywhere;
    background: transparent;
    color: var(--ink);
  }

  .lifecycle-band {
    border-block: 1px solid var(--line);
    background: var(--ink);
    color: var(--bg);
  }

  .lifecycle-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .lifecycle-step {
    min-width: 0;
    padding: 1.35rem 1.15rem 1.4rem;
    border-right: 1px solid oklch(1 0 0 / 0.14);
  }

  .lifecycle-step:last-child {
    border-right: 0;
  }

  .lifecycle-step h2 {
    margin: 0 0 0.55rem;
    color: var(--bg);
    font-size: 1.12rem;
    letter-spacing: 0;
  }

  .lifecycle-step p {
    margin: 0;
    color: oklch(0.84 0.012 24);
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .proof-section {
    display: grid;
    gap: 2rem;
  }

  .section-copy p {
    margin: 0;
    font-size: 1.05rem;
  }

  .proof-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1rem;
    align-items: stretch;
  }

  .proof-primary,
  .safeguard-list article {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }

  .proof-primary {
    display: grid;
    align-content: end;
    min-height: 310px;
    padding: 1.5rem;
    background:
      linear-gradient(145deg, var(--primary-soft), var(--surface) 52%),
      var(--surface);
  }

  .proof-primary h3,
  .safeguard-list h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.28rem;
    letter-spacing: -0.01em;
  }

  .proof-primary p,
  .safeguard-list p {
    margin: 0.65rem 0 0;
    color: var(--muted);
    line-height: 1.66;
  }

  .safeguard-list {
    display: grid;
    gap: 1rem;
  }

  .safeguard-list article {
    padding: 1.15rem;
  }

  .install-section {
    border-block: 1px solid var(--line);
    background: var(--canvas);
  }

  .install-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(420px, 1.18fr);
    gap: 3rem;
    align-items: center;
  }

  .hero > *,
  .install-grid > *,
  .proof-layout > *,
  .tools-head > *,
  .tool-row > * {
    min-width: 0;
  }

  .install-copy p {
    margin: 0;
    font-size: 1.04rem;
  }

  .tools-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 420px);
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.4rem;
  }

  .tools-head p {
    margin: 0 0 0.2rem;
    color: var(--muted);
    line-height: 1.62;
  }

  .tool-table {
    display: grid;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }

  .tool-row {
    display: grid;
    grid-template-columns: 250px minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }

  .tool-row:last-child {
    border-bottom: 0;
  }

  .tool-row code {
    width: fit-content;
    height: fit-content;
    background: var(--primary-soft);
    color: var(--primary);
    font-weight: 800;
  }

  .tool-row p {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .closing-band {
    padding: 4.75rem 0;
    background: var(--primary);
    color: var(--bg);
  }

  .closing-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .closing-band .section-label,
  .closing-band p {
    color: oklch(0.88 0.035 20);
  }

  .closing-band h2 {
    max-width: 720px;
    margin: 0 0 1rem;
    color: var(--bg);
    font-size: 2.8rem;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .closing-band p {
    margin: 0;
    max-width: 680px;
    line-height: 1.66;
  }

  .closing-band .actions {
    justify-content: flex-end;
    min-width: 300px;
  }

  .closing-band .button {
    border-color: oklch(1 0 0 / 0.34);
    background: oklch(1 0 0 / 0.08);
    color: var(--bg);
  }

  .closing-band .button:hover {
    border-color: var(--bg);
    color: var(--bg);
  }

  .closing-band .button.primary {
    border-color: var(--bg);
    background: var(--bg);
    color: var(--primary);
  }

  @media (max-width: 1040px) {
    .hero,
    .install-grid,
    .proof-layout,
    .tools-head {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 4.5rem;
    }

    h1 {
      font-size: 3.55rem;
    }

    .lifecycle-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lifecycle-step:nth-child(2) {
      border-right: 0;
    }

    .lifecycle-step:nth-child(-n + 2) {
      border-bottom: 1px solid oklch(1 0 0 / 0.14);
    }

    .closing-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .closing-band .actions {
      justify-content: flex-start;
      min-width: 0;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3.2rem 0 3.6rem;
    }

    h1 {
      max-width: 10.5ch;
      font-size: 2.36rem;
      line-height: 1.04;
      letter-spacing: -0.02em;
    }

    .lede {
      font-size: 1.05rem;
    }

    .client-list,
    .lifecycle-grid,
    .tool-row,
    .sandbox-object div {
      grid-template-columns: 1fr;
    }

    .lifecycle-step,
    .lifecycle-step:nth-child(2) {
      border-right: 0;
    }

    .lifecycle-step:not(:last-child) {
      border-bottom: 1px solid oklch(1 0 0 / 0.14);
    }

    .hero-console {
      padding: 0.75rem;
    }

    .console-head {
      grid-template-columns: auto 1fr;
    }

    .console-head code {
      grid-column: 1 / -1;
      width: fit-content;
    }

    .tool-row {
      gap: 0.65rem;
    }

    .closing-band h2 {
      font-size: 2.1rem;
    }
  }
</style>
