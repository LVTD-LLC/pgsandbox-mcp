---
import BaseLayout from '../layouts/BaseLayout.astro';

const principles = [
  {
    title: 'Private database per task',
    body: 'Each agent run gets a dedicated database and scoped login role, so migrations and SQL checks never collide with a shared dev database.'
  },
  {
    title: 'Bring your own Postgres',
    body: 'Point the MCP server at a local container, VPS, or internal dev host. PGSandbox manages databases and roles, not your infrastructure.'
  },
  {
    title: 'Clean expiration path',
    body: 'Every sandbox carries TTL metadata, labels, and cleanup commands so failed experiments do not become permanent database clutter.'
  }
];

const tools = [
  ['create_database', 'Create an isolated database and scoped role for a task.'],
  ['run_sql', 'Run SQL against a sandbox with optional readonly mode and row limits.'],
  ['describe_schema', 'Inspect tables, columns, indexes, and installed extensions.'],
  ['get_connection_string', 'Return a sandbox connection string and expiry metadata.'],
  ['list_databases', 'List active sandboxes without exposing full secrets.'],
  ['cleanup_expired', 'Delete expired resources, with dry-run support.'],
  ['delete_database', 'Remove a tracked sandbox database and role.']
];
---
<BaseLayout
  title="PGSandbox MCP - disposable Postgres for coding agents"
  description="PGSandbox MCP gives coding agents private Postgres databases for migrations, bug repros, seeded demos, and SQL validation."
>
  <main id="content">
    <section class="hero container">
      <div class="hero-copy">
        <p class="eyebrow">PGSandbox MCP</p>
        <h1>Disposable Postgres sandboxes for coding agents</h1>
        <p class="lede">
          Give every agent task its own real database, scoped credentials, and cleanup policy. Validate migrations,
          repro bugs, and inspect schemas without touching shared development state.
        </p>
        <div class="actions" aria-label="Primary actions">
          <a class="button primary" href="#start">Get started</a>
          <a class="button" href="/docs/">Read docs</a>
        </div>
      </div>

      <aside class="product-panel card" aria-label="PGSandbox MCP setup preview">
        <div class="panel-header">
          <span class="panel-title">sandbox run</span>
          <span class="panel-state">ready</span>
        </div>
        <div class="command-window shell">
          <pre><code>npm install -g pgsandbox-mcp
pgsandbox-mcp setup \
  --client codex \
  --admin-url \
  "$PGSANDBOX_ADMIN_DATABASE_URL"
pgsandbox-mcp doctor</code></pre>
        </div>
        <ol class="run-list">
          <li>
            <span>01</span>
            <strong>Agent requests a database</strong>
            <p>Creates a database and scoped role.</p>
          </li>
          <li>
            <span>02</span>
            <strong>SQL runs against real Postgres</strong>
            <p>Runs migrations, seeds, and repro SQL.</p>
          </li>
          <li>
            <span>03</span>
            <strong>Expired resources are removed</strong>
            <p>Deletes only tracked sandbox resources.</p>
          </li>
        </ol>
      </aside>
    </section>

    <dl class="container metrics" aria-label="Project highlights">
      <div>
        <dt>MCP</dt>
        <dd>tool contract</dd>
      </div>
      <div>
        <dt>TTL</dt>
        <dd>cleanup model</dd>
      </div>
      <div>
        <dt>npm</dt>
        <dd>install path</dd>
      </div>
    </dl>

    <section class="section container principles-section">
      <div class="section-head">
        <p class="eyebrow">Why it exists</p>
        <h2>The fastest database check should also be the cleanest one.</h2>
        <p>
          PGSandbox keeps agent experiments close to real production behavior while limiting blast radius to one
          task-scoped database.
        </p>
      </div>
      <div class="principle-grid">
        {principles.map((principle, index) => (
          <article class:list={['principle', { 'principle-large': index === 0 }]}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{principle.title}</h3>
            <p>{principle.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="start" class="section setup-section">
      <div class="container split">
        <div>
          <p class="eyebrow">Start in minutes</p>
          <h2>Install, register, verify.</h2>
          <p>
            Use an admin connection for a Postgres instance you control. PGSandbox creates task databases and
            limited roles under a predictable prefix.
          </p>
          <a class="text-link" href="/docs/install/">Open the full installation guide</a>
        </div>
        <div class="code-panel shell">
          <pre><code>export PGSANDBOX_ADMIN_DATABASE_URL="postgres://postgres:postgres@localhost:5432/postgres"
npm install -g pgsandbox-mcp
pgsandbox-mcp setup --client codex --admin-url "$PGSANDBOX_ADMIN_DATABASE_URL"
pgsandbox-mcp doctor</code></pre>
        </div>
      </div>
    </section>

    <section class="section container tools-section">
      <div class="section-head">
        <p class="eyebrow">MCP tool surface</p>
        <h2>A compact contract for proving database work.</h2>
      </div>
      <div class="tool-table" role="list">
        {tools.map(([name, body]) => (
          <article class="tool-row" role="listitem">
            <code>{name}</code>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-band">
      <div class="container cta-inner">
        <div>
          <p class="eyebrow">Local-first validation</p>
          <h2>Put a real Postgres sandbox in the agent loop.</h2>
          <p>Start with npm or Homebrew, then wire PGSandbox into Codex, Cursor, VS Code, or Claude Desktop.</p>
        </div>
        <div class="actions">
          <a class="button primary" href="/docs/install/">Installation guide</a>
          <a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">View repository</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 440px);
    gap: 3rem;
    align-items: center;
    padding: 2.4rem 0 1.6rem;
  }

  h1 {
    max-width: 780px;
    margin: 0.7rem 0 1.15rem;
    color: var(--ink);
    font-size: 5rem;
    line-height: 0.92;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .lede {
    max-width: 700px;
    color: var(--muted);
    font-size: 1.16rem;
    line-height: 1.72;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: -0.9rem;
    margin-bottom: 1.35rem;
  }

  .metrics div {
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.58);
  }

  .metrics dt {
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 800;
  }

  .metrics dd {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 0.93rem;
  }

  .product-panel {
    position: relative;
    min-width: 0;
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(237, 243, 236, 0.76)),
      var(--surface);
  }

  .product-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  .panel-header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.3rem 0.2rem 0.95rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .panel-title {
    color: var(--ink);
    font-family: var(--font-mono);
    font-weight: 800;
  }

  .panel-state {
    padding: 0.25rem 0.45rem;
    border: 1px solid rgba(47, 117, 107, 0.28);
    border-radius: 6px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-weight: 800;
  }

  .command-window {
    border-radius: var(--radius);
    background: #101815;
  }

  .command-window pre {
    margin: 0;
    padding: 0.72rem;
    box-shadow: none;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.8rem;
    line-height: 1.34;
  }

  .run-list {
    position: relative;
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .run-list li {
    display: grid;
    grid-template-columns: 2.35rem minmax(0, 1fr);
    gap: 0.75rem;
    padding: 0.52rem;
    border: 1px solid rgba(38, 67, 59, 0.13);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.62);
  }

  .run-list span {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 7px;
    background: var(--surface-muted);
    color: var(--accent-strong);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .run-list strong {
    display: block;
    color: var(--ink);
    font-size: 0.95rem;
  }

  .run-list p {
    grid-column: 2;
    margin: 0.15rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.28;
  }

  .section-head {
    display: grid;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .principle-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 1rem;
  }

  .principle {
    min-height: 100%;
    padding: 1.25rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.64);
  }

  .principle-large {
    grid-row: span 2;
    padding: 1.65rem;
    background: #fff;
    box-shadow: var(--shadow);
  }

  .principle span {
    color: var(--accent-strong);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .principle h3 {
    margin: 1.2rem 0 0.55rem;
    color: var(--ink);
    font-size: 1.45rem;
    letter-spacing: 0;
  }

  .principle p {
    margin: 0;
    color: var(--muted);
    line-height: 1.68;
  }

  .setup-section {
    background: rgba(237, 243, 236, 0.7);
    border-block: 1px solid var(--line);
  }

  .split {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 3rem;
    align-items: center;
  }

  .split > *,
  .hero > *,
  .tool-row > * {
    min-width: 0;
  }

  .text-link {
    display: inline-flex;
    margin-top: 0.85rem;
    color: var(--accent-strong);
    font-weight: 800;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }

  .code-panel {
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgba(38, 67, 59, 0.18);
    border-radius: var(--radius);
    background: #101815;
    box-shadow: var(--shadow);
  }

  .code-panel pre {
    margin: 0;
    padding: 0;
    border: 0;
    box-shadow: none;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .tool-table {
    display: grid;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.64);
  }

  .tool-row {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--line);
  }

  .tool-row:last-child {
    border-bottom: 0;
  }

  .tool-row code {
    color: var(--accent-strong);
    font-weight: 800;
  }

  .tool-row p {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .cta-band {
    padding: 4.75rem 0;
    background: var(--ink);
    color: #eef7f3;
  }

  .cta-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .cta-band .eyebrow,
  .cta-band p {
    color: #b7cbc3;
  }

  .cta-band h2 {
    margin: 0.65rem 0 1rem;
    max-width: 720px;
    color: #fff;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .cta-band .actions {
    justify-content: flex-end;
    min-width: 310px;
  }

  .cta-band .button {
    border-color: rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .cta-band .button.primary {
    border-color: #d8ebe6;
    background: #d8ebe6;
    color: var(--ink);
  }

  @media (max-width: 1040px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 4rem;
    }

    h1 {
      font-size: 4rem;
    }

    .product-panel {
      max-width: 720px;
    }

    .split,
    .principle-grid {
      grid-template-columns: 1fr;
    }

    .principle-large {
      grid-row: auto;
    }

    .cta-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .cta-band .actions {
      justify-content: flex-start;
      min-width: 0;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding: 3rem 0 4rem;
    }

    h1 {
      font-size: 2.85rem;
    }

    .lede {
      font-size: 1.06rem;
    }

    .metrics,
    .tool-row {
      grid-template-columns: 1fr;
    }

    .product-panel {
      padding: 0.8rem;
    }

    .run-list li {
      grid-template-columns: 1fr;
    }

    .run-list p {
      grid-column: auto;
    }

    .cta-band h2 {
      font-size: 2.25rem;
    }
  }
</style>
