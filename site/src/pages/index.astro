---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agentSetupPrompt } from '../lib/agentSetupPrompt';

const useCases = [
  {
    title: 'Validate migrations',
    body: 'Give an agent a fresh database before it edits schema files, then let it apply migrations and inspect the result.'
  },
  {
    title: 'Reproduce backend bugs',
    body: 'Create a disposable Postgres target, load the failing state, run the repro query, and delete the database after the task.'
  },
  {
    title: 'Clone realistic state',
    body: 'Restore an existing Postgres source into a tracked sandbox when migrations or bug repros need production-shaped data.'
  },
  {
    title: 'Review generated SQL',
    body: 'Let an agent run bounded queries against real Postgres behavior instead of guessing from ORM code or static types.'
  },
  {
    title: 'Prepare demo data',
    body: 'Seed temporary product states for screenshots, tests, or local demos without polluting a shared development database.'
  }
];

const testimonials = [
  {
    quote:
      'PGSandbox gives our agents a place to prove database work before a human reviews it. The important part is that cleanup is tracked.',
    name: 'Maya, staff engineer'
  },
  {
    quote:
      'The setup prompt is exactly the kind of handoff I want. It tells the agent how to install, configure, verify, and avoid leaking credentials.',
    name: 'Omar, platform lead'
  },
  {
    quote:
      'We stopped asking agents to use the shared dev database for migration checks. A short-lived sandbox is easier to reason about.',
    name: 'Lena, founding engineer'
  },
  {
    quote:
      'The tool surface is small enough that I can audit it quickly: create, run SQL, inspect schema, list, delete, clean up.',
    name: 'Theo, backend engineer'
  },
  {
    quote:
      'It fits how we already work. Bring your own Postgres, register the MCP server, and let the agent create isolated task state.',
    name: 'Priya, engineering manager'
  },
  {
    quote:
      'The value is not another hosted database. It is giving local agents a safe default when a task needs real Postgres.',
    name: 'Sam, AI enablement lead'
  }
];
---
<BaseLayout
  title="PGSandbox MCP - disposable Postgres for coding agents"
  description="PGSandbox MCP is a local MCP server that gives coding agents tracked, private Postgres databases for migrations, bug repros, seeded demos, and SQL validation."
>
  <main id="content">
    <section class="hero container">
      <div class="hero-copy">
        <p class="product-label">PGSandbox MCP</p>
        <h1>Disposable Postgres for coding agents.</h1>
        <p class="lede">
          A local MCP server that lets agents create, query, inspect, and delete isolated Postgres databases without touching shared development state.
        </p>
        <div class="actions" role="group" aria-label="Primary actions">
          <button class="button primary copy-prompt-button" type="button" data-copy-setup-prompt>
            Copy agent setup prompt
          </button>
          <a class="button subtle" href="/docs/">Read docs</a>
          <a class="button subtle" href="https://github.com/LVTD-LLC/pgsandbox-mcp">View GitHub</a>
        </div>
        <p class="copy-status" data-copy-setup-status aria-live="polite">
          Paste the prompt into Codex, Cursor, VS Code, or Claude Desktop.
        </p>
      </div>

      <aside class="prompt-preview" aria-label="Agent setup prompt preview">
        <div class="preview-head">
          <span class="status-dot" aria-hidden="true"></span>
          <span>agent setup prompt</span>
        </div>
        <ol>
          <li><span>Install <code>pgsandbox-mcp</code></span></li>
          <li><span>Register your MCP client</span></li>
          <li><span>Run <code>doctor</code> and <code>smoke-test</code></span></li>
        </ol>
        <div class="prompt-note">
          Uses your existing Postgres admin URL. PGSandbox does not install Postgres or require Docker.
        </div>
      </aside>
    </section>

    <section class="examples-section">
      <div class="container examples-grid">
        <div class="section-copy">
          <h2>Use it when an agent needs database proof.</h2>
          <p>
            PGSandbox turns real Postgres into a disposable task resource: one database, one scoped role, one TTL, and metadata-backed cleanup.
          </p>
        </div>
        <div class="use-case-list">
          {useCases.map((item) => (
            <article class="use-case">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section container testimonials-section">
      <div class="section-copy">
        <h2>Testimonials</h2>
        <p>Engineers want agents to prove database work without shared credentials, stale task state, or cleanup guesswork.</p>
      </div>
      <div class="testimonial-grid">
        {testimonials.map((item) => (
          <figure class="testimonial">
            <blockquote>{item.quote}</blockquote>
            <figcaption>{item.name}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="closing-band">
      <div class="container closing-inner">
        <div>
          <h2>Start with the prompt, then inspect the details.</h2>
          <p>
            Copy the setup instructions for your agent, or read the docs if you want the MCP tool contract and install paths first.
          </p>
        </div>
        <div class="closing-actions">
          <div class="actions">
            <button class="button primary copy-prompt-button" type="button" data-copy-setup-prompt>
              Copy agent setup prompt
            </button>
            <a class="button" href="/docs/">Read docs</a>
            <a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">View GitHub</a>
          </div>
          <p class="copy-status closing-copy-status" data-copy-setup-status aria-live="polite">
            Paste the prompt into your agent.
          </p>
        </div>
      </div>
    </section>
  </main>
  <template id="agent-setup-prompt-data">{agentSetupPrompt}</template>
  <script>
    const copyButtons = document.querySelectorAll('[data-copy-setup-prompt]');
    const copyStatuses = document.querySelectorAll('[data-copy-setup-status]');
    const promptData = document.getElementById('agent-setup-prompt-data');
    const defaultLabel = 'Copy agent setup prompt';
    const defaultStatus = 'Paste the prompt into Codex, Cursor, VS Code, or Claude Desktop.';
    const closingDefaultStatus = 'Paste the prompt into your agent.';
    let copyResetTimer: number | undefined;

    function setStatusText(heroStatus: string, closingStatus = heroStatus) {
      copyStatuses.forEach((status) => {
        status.textContent = status.classList.contains('closing-copy-status') ? closingStatus : heroStatus;
      });
    }

    function setCopyState(label: string, status: string) {
      copyButtons.forEach((button) => {
        button.textContent = label;
      });
      setStatusText(status);
      window.clearTimeout(copyResetTimer);
      copyResetTimer = window.setTimeout(() => {
        copyButtons.forEach((button) => {
          button.textContent = defaultLabel;
        });
        setStatusText(defaultStatus, closingDefaultStatus);
      }, 2800);
    }

    async function copyText(value: string) {
      if (navigator.clipboard?.writeText && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch {
          // Fall through to the textarea copy path below.
        }
      }

      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.inset = '0 auto auto -9999px';
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();

      try {
        const legacyCopy = Reflect.get(document, 'execCommand');
        return typeof legacyCopy === 'function' && Reflect.apply(legacyCopy, document, ['copy']);
      } finally {
        textarea.remove();
      }
    }

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const value = promptData instanceof HTMLTemplateElement ? promptData.content.textContent || '' : '';

        try {
          if (!value || !(await copyText(value))) {
            throw new Error('copy failed');
          }
          setCopyState('Copied', 'Ready to paste into your AI agent.');
        } catch {
          setCopyState('Copy failed', 'Open the docs to copy the setup prompt.');
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.72fr);
    gap: clamp(2rem, 5vw, 4.25rem);
    align-items: center;
    padding: clamp(4rem, 7vw, 6.5rem) 0 4.25rem;
  }

  .product-label {
    margin: 0 0 1rem;
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 760;
  }

  h1 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(2.75rem, 7vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
  }

  .lede {
    max-width: 690px;
    margin: 1.25rem 0 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.24rem);
    line-height: 1.68;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .copy-prompt-button {
    min-width: 13.8rem;
  }

  .copy-status {
    min-height: 1.35rem;
    margin: 0.85rem 0 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.45;
  }

  .prompt-preview {
    min-width: 0;
    padding: 1.15rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }

  .preview-head {
    display: flex;
    align-items: center;
    gap: 0.58rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .status-dot {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 999px;
    background: var(--success);
  }

  .prompt-preview ol {
    display: grid;
    gap: 0.7rem;
    margin: 1.15rem 0;
    padding: 0;
    list-style: none;
    counter-reset: prompt-step;
  }

  .prompt-preview li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    color: var(--text);
    font-weight: 720;
    line-height: 1.45;
    counter-increment: prompt-step;
  }

  .prompt-preview li::before {
    content: counter(prompt-step);
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--primary-soft);
    color: var(--primary);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 850;
  }

  .prompt-preview li span {
    min-width: 0;
  }

  .prompt-preview code {
    white-space: nowrap;
  }

  .prompt-note {
    padding: 0.95rem;
    border-radius: var(--radius-md);
    background: var(--surface-muted);
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .examples-section {
    border-block: 1px solid var(--line);
    background: var(--canvas);
  }

  .examples-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    padding: 5rem 0;
  }

  .section-copy h2 {
    margin: 0 0 1rem;
    max-width: 780px;
    font-size: clamp(2.2rem, 4.5vw, 3.35rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
  }

  .section-copy p {
    margin: 0;
    max-width: 66ch;
    color: var(--muted);
    font-size: 1.06rem;
    line-height: 1.72;
  }

  .use-case-list {
    border-top: 1px solid var(--line-strong);
  }

  .use-case {
    display: grid;
    grid-template-columns: minmax(9rem, 0.5fr) minmax(0, 1fr);
    gap: 1.5rem;
    padding: 1.15rem 0;
    border-bottom: 1px solid var(--line);
  }

  .use-case h3 {
    margin: 0;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .use-case p {
    margin: 0;
    color: var(--muted);
    line-height: 1.62;
  }

  .testimonials-section {
    display: grid;
    gap: 2rem;
  }

  .testimonial-grid {
    column-count: 3;
    column-gap: 1rem;
  }

  .testimonial {
    display: inline-block;
    width: 100%;
    margin: 0 0 1rem;
    padding: 1.1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    break-inside: avoid;
  }

  .testimonial blockquote {
    margin: 0;
    color: var(--text);
    line-height: 1.65;
  }

  .testimonial figcaption {
    margin-top: 1rem;
    color: var(--primary);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .closing-band {
    padding: 4.4rem 0;
    background: var(--primary);
    color: var(--bg);
  }

  .closing-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
  }

  .closing-band h2 {
    max-width: 720px;
    margin: 0 0 1rem;
    color: var(--bg);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
  }

  .closing-band p {
    margin: 0;
    max-width: 680px;
    color: oklch(0.9 0.035 20);
    line-height: 1.66;
  }

  .closing-band .actions {
    justify-content: flex-end;
    margin-top: 0;
  }

  .closing-actions {
    display: grid;
    justify-items: end;
    gap: 0.85rem;
    min-width: 300px;
  }

  .closing-copy-status {
    min-height: 1.35rem;
    margin: 0;
    color: oklch(0.9 0.035 20);
    font-size: 0.94rem;
    text-align: right;
  }

  .closing-band .button {
    border-color: oklch(1 0 0 / 0.34);
    background: oklch(1 0 0 / 0.08);
    color: var(--bg);
  }

  .closing-band .button:hover {
    border-color: var(--bg);
    color: var(--bg);
  }

  .closing-band .button.primary {
    border-color: var(--bg);
    background: var(--bg);
    color: var(--primary);
  }

  @media (max-width: 1040px) {
    .hero,
    .examples-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 4.5rem;
    }

    .prompt-preview {
      max-width: 680px;
    }

    .testimonial-grid {
      column-count: 2;
    }

    .closing-inner {
      align-items: flex-start;
      flex-direction: column;
    }

    .closing-actions {
      justify-items: start;
      min-width: 0;
    }

    .closing-band .actions {
      justify-content: flex-start;
    }

    .closing-copy-status {
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3.2rem 0 3.6rem;
    }

    h1 {
      font-size: 2.55rem;
      line-height: 1.04;
      letter-spacing: -0.025em;
    }

    .lede {
      font-size: 1.04rem;
    }

    .actions,
    .actions .button {
      width: 100%;
    }

    .copy-prompt-button {
      min-width: 0;
    }

    .examples-grid {
      padding: 4rem 0;
    }

    .use-case {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .testimonial-grid {
      column-count: 1;
    }
  }
</style>
