---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agentSetupPrompt } from '../lib/agentSetupPrompt';

const useCases = [
  {
    title: 'Test database migrations',
    body: 'Apply schema changes to a real Postgres test database before they reach shared development or staging.'
  },
  {
    title: 'Validate SQL and query plans',
    body: 'Run generated SQL, inspect schemas, and check query plans against the database engine that will execute them.'
  },
  {
    title: 'Reproduce backend bugs',
    body: 'Build the failing state in isolation, test the fix, and delete the database when the investigation ends.'
  },
  {
    title: 'Seed product demos',
    body: 'Give screenshots, local demos, and acceptance tests realistic data without polluting a shared environment.'
  },
  {
    title: 'Clone realistic test data',
    body: 'Restore an existing Postgres source into a tracked, disposable database for higher-confidence validation.'
  }
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'PGSandbox',
  applicationCategory: 'DeveloperApplication',
  description: 'A local Postgres MCP server for disposable database sandboxes used by coding agents.',
  url: 'https://pgsandbox.lvtd.dev/',
  codeRepository: 'https://github.com/LVTD-LLC/pgsandbox',
  license: 'https://github.com/LVTD-LLC/pgsandbox/blob/main/LICENSE',
  softwareRequirements: 'PostgreSQL server binaries'
};
---
<BaseLayout
  title="PGSandbox — Postgres MCP Server for Coding Agents"
  description="PGSandbox is a local Postgres MCP server that gives coding agents isolated database sandboxes for migrations, SQL testing, and backend bug reproduction."
  structuredData={structuredData}
>
  <main id="content" class="landing-page">
    <section class="hero-section">
      <div class="container hero-inner">
        <p class="hero-kicker"><span>Open source</span><i aria-hidden="true"></i>Local-first Postgres MCP server</p>
        <h1>Safe Postgres for coding agents.</h1>
        <p class="hero-summary">
          PGSandbox gives each agent task an isolated database, then cleans it up when the work is done.
        </p>
        <div class="hero-action">
          <button class="button primary copy-prompt-button" type="button" data-copy-setup-prompt>
            Copy the agent setup prompt
          </button>
          <p class="copy-status" data-copy-setup-status aria-live="polite">
            Paste it into Codex, Cursor, VS Code, or Claude Desktop. Your agent handles setup and verification.
          </p>
        </div>
        <a class="install-link" href="/docs/install/">Prefer to install it yourself? Read the installation guide →</a>
      </div>
    </section>

    <section class="trust-section" aria-label="PGSandbox at a glance">
      <dl class="container trust-list">
        <div>
          <dt>Local-first</dt>
          <dd>Runs on your machine. No hosted account required.</dd>
        </div>
        <div>
          <dt>Isolated per task</dt>
          <dd>One database and one scoped login for each agent job.</dd>
        </div>
        <div>
          <dt>Tracked cleanup</dt>
          <dd>TTL limits and metadata keep deletion bounded to owned resources.</dd>
        </div>
      </dl>
    </section>

    <section class="workflow-section">
      <div class="container workflow-grid">
        <div class="section-heading">
          <p class="eyebrow">What it does</p>
          <h2>A database sandbox for work that needs proof.</h2>
          <p>
            Your agent gets real Postgres behavior without access to a shared developer database or long-lived task state.
          </p>
        </div>
        <dl class="workflow-list">
          <div>
            <dt><span>01</span>Create</dt>
            <dd>PGSandbox creates a temporary database, a restricted login role, and an expiry time.</dd>
          </div>
          <div>
            <dt><span>02</span>Prove</dt>
            <dd>Your agent runs migrations, SQL, seed commands, schema checks, or a backend reproduction.</dd>
          </div>
          <div>
            <dt><span>03</span>Delete</dt>
            <dd>PGSandbox removes the tracked database and role after the task, or when the TTL expires.</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="use-cases-section">
      <div class="container">
        <div class="section-heading use-cases-heading">
          <p class="eyebrow">What it’s for</p>
          <h2>Use real Postgres without risking shared state.</h2>
          <p>
            PGSandbox is for engineering tasks where static analysis is not enough and the agent needs a database to verify its work.
          </p>
        </div>
        <dl class="use-case-list">
          {useCases.map((item, index) => (
            <div>
              <dt><span>0{index + 1}</span>{item.title}</dt>
              <dd>{item.body}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <section class="safety-section">
      <div class="container safety-grid">
        <div class="section-heading">
          <p class="eyebrow">Designed for local agent work</p>
          <h2>Small enough to understand. Strict where it matters.</h2>
        </div>
        <dl class="safety-list">
          <div>
            <dt>Leaves your existing Postgres alone</dt>
            <dd>The managed local runtime uses its own data directory and a separate high port instead of taking over port 5432.</dd>
          </div>
          <div>
            <dt>Separates lifecycle access from query access</dt>
            <dd>Admin connections manage databases. Agent SQL runs through the sandbox’s restricted role.</dd>
          </div>
          <div>
            <dt>Bounds agent output and lifetime</dt>
            <dd>Row limits, result truncation, positive TTLs, and ownership metadata keep experiments contained.</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="closing-section">
      <div class="container closing-inner">
        <div class="section-heading">
          <p class="eyebrow">Agent-assisted setup</p>
          <h2>Let your agent handle the setup.</h2>
          <p>
            One prompt tells your agent how to install PGSandbox, configure its MCP client, and verify the complete create-query-delete workflow.
          </p>
        </div>
        <div class="closing-action">
          <button class="closing-copy-button" type="button" data-copy-setup-prompt>
            Copy the setup prompt →
          </button>
          <p class="copy-status" data-copy-setup-status aria-live="polite">Ready for your coding agent.</p>
        </div>
      </div>
    </section>
  </main>

  <template id="agent-setup-prompt-data">{agentSetupPrompt}</template>
  <script>
    const copyButtons = document.querySelectorAll('[data-copy-setup-prompt]');
    const copyStatuses = document.querySelectorAll('[data-copy-setup-status]');
    const promptData = document.getElementById('agent-setup-prompt-data');
    const resetTimers = new WeakMap<Element, number>();

    async function copyText(value: string) {
      if (navigator.clipboard?.writeText && window.isSecureContext) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch {
          // Fall through to the browser-compatible copy path.
        }
      }

      const textarea = document.createElement('textarea');
      textarea.value = value;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.inset = '0 auto auto -9999px';
      document.body.appendChild(textarea);
      textarea.select();

      try {
        const legacyCopy = Reflect.get(document, 'execCommand');
        return typeof legacyCopy === 'function' && Reflect.apply(legacyCopy, document, ['copy']);
      } finally {
        textarea.remove();
      }
    }

    copyButtons.forEach((button) => {
      const defaultLabel = button.textContent || 'Copy the setup prompt';

      button.addEventListener('click', async () => {
        const value = promptData instanceof HTMLTemplateElement ? promptData.content.textContent || '' : '';
        const existingTimer = resetTimers.get(button);
        if (existingTimer) window.clearTimeout(existingTimer);

        try {
          if (!value || !(await copyText(value))) throw new Error('copy failed');
          button.textContent = 'Prompt copied';
          copyStatuses.forEach((status) => status.textContent = 'Ready to paste into your coding agent.');
        } catch {
          button.textContent = 'Copy failed';
          copyStatuses.forEach((status) => status.textContent = 'Open the installation guide to copy the setup prompt.');
        }

        const timer = window.setTimeout(() => {
          button.textContent = defaultLabel;
        }, 2800);
        resetTimers.set(button, timer);
      });
    });
  </script>
</BaseLayout>

<style>
  .landing-page {
    isolation: isolate;
    background: #fffdf8;
    color: #272520;
  }

  .hero-section {
    padding: clamp(4.5rem, 10vw, 8.5rem) 0 clamp(4rem, 8vw, 7rem);
  }

  .hero-inner {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0 0 1.35rem;
    color: #68635a;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .hero-kicker span {
    color: #8d6214;
  }

  .hero-kicker i {
    width: 0.25rem;
    height: 0.25rem;
    flex: 0 0 auto;
    border-radius: 50%;
    background: #b8ad9b;
  }

  h1,
  h2 {
    color: #1e1c18;
    text-wrap: balance;
  }

  h1 {
    max-width: 14ch;
    margin: 0;
    font-size: clamp(3.4rem, 8.5vw, 7.2rem);
    font-weight: 760;
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  h2 {
    max-width: 21ch;
    margin: 0;
    font-size: clamp(2.35rem, 5vw, 4rem);
    font-weight: 720;
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .hero-summary {
    max-width: 48ch;
    margin: 1.5rem 0 0;
    color: #5f5a52;
    font-size: clamp(1.12rem, 2vw, 1.28rem);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .hero-action {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    margin-top: 2.1rem;
  }

  .copy-prompt-button {
    min-width: 17.5rem;
    min-height: 3.25rem;
    padding: 0.82rem 1.15rem;
    border-radius: 10px;
  }

  .copy-status {
    max-width: 64ch;
    min-height: 1.35rem;
    margin: 0;
    color: #716b61;
    font-size: 0.94rem;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .install-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin-top: 0.65rem;
    color: #5f5a52;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: #c8beb0;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .install-link:hover {
    color: var(--primary);
  }

  .trust-section {
    border-block: 1px solid rgba(39, 37, 32, 0.12);
    background: #ffffff;
  }

  .trust-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .trust-list > div {
    min-width: 0;
    padding: 1.6rem 2rem;
  }

  .trust-list > div:first-child {
    padding-left: 0;
  }

  .trust-list > div:last-child {
    padding-right: 0;
  }

  .trust-list > div + div {
    border-left: 1px solid rgba(39, 37, 32, 0.1);
  }

  .trust-list dt {
    color: #272520;
    font-weight: 780;
  }

  .trust-list dd {
    margin: 0.4rem 0 0;
    color: #716b61;
    font-size: 0.94rem;
    line-height: 1.55;
  }

  .workflow-section {
    padding: clamp(5rem, 9vw, 7.5rem) 0;
    background: #18231e;
    color: #c7d0ca;
  }

  .workflow-grid,
  .safety-grid,
  .closing-inner {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(3rem, 7vw, 6rem);
    align-items: start;
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: #2d6b50;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .section-heading > p:last-child {
    max-width: 58ch;
    margin: 1.15rem 0 0;
    color: #716b61;
    font-size: 1.04rem;
    line-height: 1.7;
    text-wrap: pretty;
  }

  .workflow-section .eyebrow,
  .closing-section .eyebrow {
    color: #86c89e;
  }

  .workflow-section h2,
  .closing-section h2 {
    color: #f7faf8;
  }

  .workflow-section .section-heading > p:last-child,
  .closing-section .section-heading > p:last-child {
    color: #aab7af;
  }

  .workflow-list {
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .workflow-list > div {
    display: grid;
    grid-template-columns: minmax(9rem, 4fr) minmax(0, 7fr);
    gap: 1.5rem;
    padding: 1.45rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
  }

  .workflow-list dt {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 750;
  }

  .workflow-list dt span {
    color: #86c89e;
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .workflow-list dd {
    margin: 0;
    color: #aab7af;
    line-height: 1.65;
  }

  .use-cases-section {
    padding: clamp(5rem, 9vw, 7.5rem) 0;
    background: #fffdf8;
  }

  .use-cases-heading {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    column-gap: clamp(3rem, 7vw, 6rem);
    align-items: end;
  }

  .use-cases-heading .eyebrow {
    grid-column: 1 / -1;
  }

  .use-cases-heading > p:last-child {
    margin-top: 0;
  }

  .use-case-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(3rem, 7vw, 6rem);
    margin: 3.5rem 0 0;
    border-top: 1px solid rgba(39, 37, 32, 0.18);
  }

  .use-case-list > div {
    display: grid;
    grid-template-columns: minmax(10rem, 4fr) minmax(0, 7fr);
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(39, 37, 32, 0.12);
  }

  .use-case-list dt {
    display: grid;
    gap: 0.55rem;
    color: #272520;
    font-size: 1.04rem;
    font-weight: 760;
  }

  .use-case-list dt span {
    color: #9b6c17;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .use-case-list dd {
    margin: 0;
    color: #716b61;
    line-height: 1.62;
  }

  .safety-section {
    padding: clamp(5rem, 9vw, 7.5rem) 0;
    border-block: 1px solid rgba(39, 37, 32, 0.12);
    background: #f2eee5;
  }

  .safety-list {
    margin: 0;
    border-top: 1px solid rgba(39, 37, 32, 0.18);
  }

  .safety-list > div {
    padding: 1.4rem 0;
    border-bottom: 1px solid rgba(39, 37, 32, 0.13);
  }

  .safety-list dt {
    color: #272520;
    font-size: 1.08rem;
    font-weight: 760;
  }

  .safety-list dd {
    margin: 0.55rem 0 0;
    color: #68635a;
    line-height: 1.65;
  }

  .closing-section {
    padding: clamp(4.5rem, 8vw, 6.5rem) 0;
    background: #18231e;
  }

  .closing-inner {
    align-items: end;
  }

  .closing-action {
    display: grid;
    justify-items: start;
    gap: 0.8rem;
  }

  .closing-copy-button {
    min-height: 48px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #bce8cb;
    font: inherit;
    font-size: 1.08rem;
    font-weight: 800;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 5px;
    cursor: pointer;
  }

  .closing-copy-button:hover {
    color: #ffffff;
  }

  .closing-section .copy-status {
    color: #91a097;
  }

  @media (max-width: 960px) {
    .workflow-grid,
    .safety-grid,
    .closing-inner,
    .use-cases-heading {
      grid-template-columns: 1fr;
    }

    .use-cases-heading > p:last-child {
      margin-top: 1.15rem;
    }

    .use-case-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .hero-section {
      padding: 3.5rem 0 4rem;
    }

    .hero-kicker {
      flex-wrap: wrap;
      justify-content: center;
      font-size: 0.76rem;
    }

    h1 {
      font-size: clamp(3rem, 15vw, 4.5rem);
      line-height: 0.98;
    }

    .hero-summary,
    .section-heading > p:last-child {
      font-size: 1.05rem;
    }

    .hero-action,
    .copy-prompt-button {
      width: 100%;
    }

    .trust-list {
      grid-template-columns: 1fr;
    }

    .trust-list > div,
    .trust-list > div:first-child,
    .trust-list > div:last-child {
      padding: 1.25rem 0;
    }

    .trust-list > div + div {
      border-top: 1px solid rgba(39, 37, 32, 0.1);
      border-left: 0;
    }

    .workflow-list > div,
    .use-case-list > div {
      grid-template-columns: 1fr;
      gap: 0.65rem;
    }

    .workflow-list dt,
    .use-case-list dt {
      display: flex;
      align-items: baseline;
    }
  }
</style>
