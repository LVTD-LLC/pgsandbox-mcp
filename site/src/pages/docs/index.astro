---
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = [
  ['Install and setup', '/docs/install/', 'npm, npx, Homebrew, and verification commands.'],
  ['MCP tools', '/docs/mcp-tools/', 'The v0 tool contract exposed to MCP clients.'],
  ['Architecture', '/docs/architecture/', 'How PGSandbox maps agents to isolated Postgres databases.'],
  ['Homebrew packaging', '/docs/homebrew/', 'Formula shape and release checklist.']
];
---
<BaseLayout title="PGSandbox MCP docs"><main class="container docs-home"><p class="eyebrow">Documentation</p><h1>Run real Postgres checks from your agent workflow.</h1><p class="intro">These docs cover installation, MCP tool behavior, architecture, and packaging notes for the early PGSandbox MCP release.</p><div class="doc-grid">{docs.map(([title, href, body]) => <a class="card doc-card" href={href}><h2>{title}</h2><p>{body}</p></a>)}</div></main></BaseLayout>
<style>.docs-home{padding:5rem 0 7rem}h1{max-width:880px;margin:.5rem 0 1rem;font-size:clamp(2.8rem,6vw,5.8rem);line-height:.9;letter-spacing:-.08em}.intro{max-width:720px;color:var(--muted);font-size:1.15rem;line-height:1.7}.doc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin-top:2rem}.doc-card{padding:1.4rem;box-shadow:none}.doc-card h2{margin:0 0 .5rem}.doc-card p{margin:0;color:var(--muted);line-height:1.6}.doc-card:hover{border-color:rgba(77,240,255,.55)}@media(max-width:760px){.doc-grid{grid-template-columns:1fr}}</style>
