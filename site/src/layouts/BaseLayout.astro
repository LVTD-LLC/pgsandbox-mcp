---
const {
  title = 'PGSandbox MCP',
  description = 'Agent-facing MCP server for disposable Postgres sandboxes.'
} = Astro.props;

const pathname = Astro.url.pathname;
const isDocs = pathname.startsWith('/docs');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: oklch(1 0 0);
        --canvas: oklch(0.972 0 0);
        --surface: oklch(0.995 0 0);
        --surface-muted: oklch(0.952 0.007 24);
        --surface-tint: oklch(0.955 0.024 20);
        --ink: oklch(0.18 0.014 24);
        --text: oklch(0.27 0.016 24);
        --muted: oklch(0.42 0.016 24);
        --quiet: oklch(0.54 0.014 24);
        --line: oklch(0.875 0.01 24);
        --line-strong: oklch(0.735 0.018 24);
        --primary: oklch(0.4 0.13 20);
        --primary-hover: oklch(0.34 0.13 20);
        --primary-soft: oklch(0.94 0.036 20);
        --accent: oklch(0.42 0.085 188);
        --accent-hover: oklch(0.35 0.085 188);
        --accent-soft: oklch(0.94 0.045 188);
        --success: oklch(0.45 0.095 150);
        --warning: oklch(0.58 0.12 72);
        --code-bg: oklch(0.14 0.012 24);
        --code-ink: oklch(0.94 0.012 168);
        --code-muted: oklch(0.71 0.022 168);
        --radius-sm: 6px;
        --radius-md: 10px;
        --radius-lg: 14px;
        --shadow-short: 0 1px 2px oklch(0 0 0 / 0.08);
        --font-sans: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "SFMono-Regular", "Cascadia Code", Consolas, "Liberation Mono", ui-monospace, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        overflow-x: clip;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        background:
          linear-gradient(180deg, var(--canvas) 0, var(--bg) 23rem),
          var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        overflow-x: clip;
        text-rendering: optimizeLegibility;
      }

      ::selection {
        background: var(--primary-soft);
        color: var(--ink);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:focus-visible,
      button:focus-visible {
        outline: 3px solid oklch(0.4 0.13 20 / 0.3);
        outline-offset: 3px;
      }

      p {
        text-wrap: pretty;
        overflow-wrap: break-word;
      }

      h1,
      h2,
      h3 {
        color: var(--ink);
        text-wrap: balance;
        overflow-wrap: break-word;
      }

      code,
      pre {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
      }

      :not(pre) > code {
        padding: 0.08rem 0.28rem;
        border-radius: var(--radius-sm);
        background: var(--surface-tint);
        color: var(--primary);
        font-size: 0.91em;
        font-weight: 700;
      }

      pre {
        width: 100%;
        max-width: 100%;
        overflow-x: auto;
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid oklch(0.37 0.015 24);
        border-radius: var(--radius-md);
        background: var(--code-bg);
        color: var(--code-ink);
        line-height: 1.62;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
      }

      pre code {
        padding: 0;
        border-radius: 0;
        background: transparent;
        color: inherit;
        font-size: 0.91rem;
        font-weight: 500;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .shell::before {
        content: "terminal";
        display: block;
        margin-bottom: 0.75rem;
        color: var(--code-muted);
        font-family: var(--font-sans);
        font-size: 0.78rem;
        font-weight: 750;
      }

      .skip-link {
        position: fixed;
        left: 1rem;
        top: 1rem;
        z-index: 50;
        transform: translateY(-150%);
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        background: var(--ink);
        color: var(--bg);
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .container {
        width: min(1180px, calc(100% - clamp(2rem, 6vw, 5rem)));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--line);
        background: oklch(1 0 0 / 0.94);
        backdrop-filter: blur(14px);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 68px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.72rem;
        color: var(--ink);
        font-weight: 800;
      }

      .brand-mark {
        display: grid;
        place-items: center;
        width: 36px;
        height: 36px;
        border-radius: var(--radius-md);
        background: var(--primary);
        color: var(--bg);
        font-family: var(--font-mono);
        font-size: 0.82rem;
        box-shadow: inset 0 -1px 0 oklch(1 0 0 / 0.18);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.2rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0.58rem 0.72rem;
        border-radius: var(--radius-md);
        font-weight: 650;
        transition:
          background 180ms ease,
          color 180ms ease;
      }

      .nav-link:hover,
      .nav-link[aria-current] {
        background: var(--primary-soft);
        color: var(--primary);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 0.68rem 0.95rem;
        border: 1px solid var(--line-strong);
        border-radius: var(--radius-md);
        background: var(--bg);
        color: var(--ink);
        font-weight: 760;
        transition:
          transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 180ms ease,
          background 180ms ease,
          color 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
        border-color: var(--primary);
        color: var(--primary);
      }

      .button:active {
        transform: translateY(0);
      }

      .button.primary {
        border-color: var(--primary);
        background: var(--primary);
        color: var(--bg);
        box-shadow: inset 0 -1px 0 oklch(0 0 0 / 0.22);
      }

      .button.primary:hover {
        background: var(--primary-hover);
        color: var(--bg);
      }

      .button.subtle {
        border-color: var(--line);
        background: var(--surface-muted);
      }

      .button.subtle:hover {
        background: var(--primary-soft);
      }

      .section {
        padding: 5.5rem 0;
      }

      .section h2 {
        margin: 0 0 1rem;
        max-width: 820px;
        font-size: 2.9rem;
        line-height: 1.02;
        letter-spacing: -0.02em;
      }

      .section p {
        max-width: 68ch;
        color: var(--muted);
        line-height: 1.72;
      }

      .section-label {
        display: inline-flex;
        width: fit-content;
        margin: 0 0 1rem;
        color: var(--primary);
        font-family: var(--font-mono);
        font-size: 0.86rem;
        font-weight: 760;
      }

      .text-link {
        display: inline-flex;
        align-items: center;
        margin-top: 0.85rem;
        color: var(--primary);
        font-weight: 800;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        text-underline-offset: 4px;
      }

      .text-link:hover {
        color: var(--primary-hover);
      }

      .code-panel {
        min-width: 0;
        padding: 1rem;
        border-radius: var(--radius-lg);
        background: var(--code-bg);
      }

      .code-panel pre {
        margin: 0;
        padding: 0;
        border: 0;
        background: transparent;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .footer {
        border-top: 1px solid var(--line);
        background: var(--canvas);
        color: var(--muted);
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.35rem 0;
        font-size: 0.94rem;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .footer a {
        color: var(--ink);
        font-weight: 750;
      }

      .footer a:hover {
        color: var(--primary);
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }

      @media (max-width: 860px) {
        p {
          text-wrap: wrap;
        }

        h1,
        h2,
        h3 {
          text-wrap: wrap;
        }

        .nav-inner {
          align-items: flex-start;
          flex-direction: column;
          gap: 0.75rem;
          padding: 0.85rem 0;
        }

        .nav-links {
          width: 100%;
          flex-wrap: wrap;
        }

        .nav-link {
          padding-inline: 0.65rem;
        }

        .nav-links .hide-sm {
          display: none;
        }

        .section {
          padding: 4rem 0;
        }

        .section h2 {
          font-size: 2.15rem;
          line-height: 1.08;
        }

        .footer-inner {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <nav class="nav" aria-label="Primary">
      <div class="container nav-inner">
        <a class="brand" href="/" aria-label="PGSandbox MCP home">
          <span class="brand-mark">pg</span>
          <span>PGSandbox MCP</span>
        </a>
        <div class="nav-links">
          <a class="nav-link" href="/#start">Install</a>
          <a class="nav-link" href="/docs/" aria-current={isDocs ? 'true' : undefined}>Docs</a>
          <a class="nav-link hide-sm" href="/docs/mcp-tools/">MCP tools</a>
          <a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">View GitHub</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="container footer-inner">
        <span>Local Postgres sandboxes for agent work that needs proof.</span>
        <div class="footer-links">
          <a href="/docs/install/">Install package</a>
          <a href="https://github.com/LVTD-LLC/pgsandbox-mcp/blob/main/LICENSE">Read MIT license</a>
        </div>
      </div>
    </footer>
  </body>
</html>
