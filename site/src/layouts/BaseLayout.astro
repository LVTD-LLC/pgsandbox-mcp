---
const {
  title = 'PGSandbox MCP',
  description = 'Agent-facing MCP server for disposable Postgres sandboxes.'
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root { color-scheme: dark; --bg:#050712; --text:#eef5ff; --muted:#9fb0c8; --line:rgba(149,180,255,.18); --cyan:#4df0ff; --violet:#a877ff; --lime:#9cff87; --shadow:0 28px 90px rgba(31,97,255,.25); font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; }
      *{box-sizing:border-box} body{margin:0;min-height:100vh;background:radial-gradient(circle at 20% 10%,rgba(77,240,255,.18),transparent 30rem),radial-gradient(circle at 78% 18%,rgba(168,119,255,.22),transparent 28rem),radial-gradient(circle at 50% 92%,rgba(156,255,135,.12),transparent 24rem),var(--bg);color:var(--text)}
      body::before{content:"";position:fixed;inset:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px);background-size:44px 44px;mask-image:linear-gradient(to bottom,rgba(0,0,0,.8),transparent 72%)}
      a{color:inherit;text-decoration:none} code,pre{font-family:"SFMono-Regular",Consolas,"Liberation Mono",monospace} pre{overflow-x:auto;padding:1rem;border:1px solid var(--line);border-radius:18px;background:rgba(1,5,16,.72)} code{color:#c6f8ff}.shell::before{content:"terminal";display:block;margin-bottom:.7rem;color:var(--muted);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase}
      .container{width:min(1120px,calc(100% - 40px));margin:0 auto}.nav{position:sticky;top:0;z-index:20;backdrop-filter:blur(20px);border-bottom:1px solid var(--line);background:rgba(5,7,18,.72)}.nav-inner{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem 0}.brand{display:flex;align-items:center;gap:.7rem;font-weight:800;letter-spacing:-.03em}.brand-mark{display:grid;place-items:center;width:34px;height:34px;border-radius:12px;background:linear-gradient(135deg,var(--cyan),var(--violet));color:#06101c;box-shadow:0 0 30px rgba(77,240,255,.35)}.nav-links{display:flex;gap:1rem;align-items:center;color:var(--muted);font-size:.95rem}.nav-links a:hover{color:var(--text)}
      .button{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.78rem 1rem;border-radius:999px;border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);color:var(--text);font-weight:700;transition:transform .18s ease,border-color .18s ease,background .18s ease}.button:hover{transform:translateY(-2px);border-color:rgba(77,240,255,.55);background:rgba(77,240,255,.1)}.button.primary{border:none;color:#06101c;background:linear-gradient(135deg,var(--cyan),var(--lime));box-shadow:0 16px 48px rgba(77,240,255,.25)}.eyebrow{color:var(--cyan);font-weight:800;letter-spacing:.16em;text-transform:uppercase;font-size:.78rem}.card{border:1px solid var(--line);border-radius:26px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.035));box-shadow:var(--shadow)}.section{padding:5.5rem 0}.section h2{margin:.6rem 0 1rem;font-size:clamp(2rem,4vw,3.4rem);line-height:.98;letter-spacing:-.06em}.section p{color:var(--muted);line-height:1.7}.footer{border-top:1px solid var(--line);color:var(--muted);padding:2rem 0}@media(max-width:760px){.nav-links{gap:.7rem;font-size:.85rem}.nav-links .hide-sm{display:none}.section{padding:3.6rem 0}}
    </style>
  </head>
  <body>
    <nav class="nav"><div class="container nav-inner"><a class="brand" href="/" aria-label="PGSandbox MCP home"><span class="brand-mark">pg</span><span>PGSandbox MCP</span></a><div class="nav-links"><a href="/#start">Start</a><a href="/docs/">Docs</a><a class="hide-sm" href="/docs/mcp-tools/">MCP tools</a><a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">GitHub</a></div></div></nav>
    <slot />
    <footer class="footer"><div class="container">Built for agents that need real Postgres without shared-database chaos.</div></footer>
  </body>
</html>
