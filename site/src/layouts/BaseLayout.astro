---
const {
  title = 'PGSandbox MCP',
  description = 'Agent-facing MCP server for disposable Postgres sandboxes.'
} = Astro.props;

const pathname = Astro.url.pathname;
const isDocs = pathname.startsWith('/docs');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#f4f7f2" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f4f7f2;
        --bg-strong: #e7eee6;
        --surface: #ffffff;
        --surface-muted: #edf3ec;
        --ink: #111a17;
        --text: #1c2925;
        --muted: #60716b;
        --faint: #82908b;
        --line: rgba(38, 67, 59, 0.16);
        --line-strong: rgba(38, 67, 59, 0.28);
        --accent: #2f756b;
        --accent-strong: #1f5d55;
        --accent-soft: #d8ebe6;
        --shadow: 0 24px 70px rgba(28, 61, 53, 0.11);
        --radius: 8px;
        --font-sans: "Aptos", "Segoe UI Variable", "Segoe UI", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: "SFMono-Regular", Consolas, "Liberation Mono", ui-monospace, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100dvh;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.86), rgba(244, 247, 242, 0.92) 28rem),
          repeating-linear-gradient(90deg, rgba(47, 117, 107, 0.035) 0 1px, transparent 1px 72px),
          var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        text-rendering: optimizeLegibility;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.38;
        background-image:
          linear-gradient(rgba(17, 26, 23, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(17, 26, 23, 0.025) 1px, transparent 1px);
        background-size: 24px 24px;
        mask-image: linear-gradient(to bottom, #000 0%, transparent 62%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:focus-visible,
      button:focus-visible {
        outline: 3px solid rgba(47, 117, 107, 0.34);
        outline-offset: 3px;
      }

      p {
        text-wrap: pretty;
      }

      code,
      pre {
        font-family: var(--font-mono);
        font-variant-numeric: tabular-nums;
      }

      code {
        color: var(--accent-strong);
        font-size: 0.94em;
      }

      pre {
        max-width: 100%;
        overflow-x: auto;
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid rgba(38, 67, 59, 0.18);
        border-radius: var(--radius);
        background: #101815;
        color: #e8f4ef;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }

      pre code {
        color: inherit;
      }

      .shell::before {
        content: "Terminal";
        display: block;
        margin-bottom: 0.75rem;
        color: #9fb5ad;
        font-family: var(--font-sans);
        font-size: 0.78rem;
        font-weight: 700;
      }

      .skip-link {
        position: fixed;
        left: 1rem;
        top: 1rem;
        z-index: 100;
        transform: translateY(-150%);
        padding: 0.75rem 1rem;
        border-radius: var(--radius);
        background: var(--ink);
        color: #fff;
        transition: transform 160ms ease;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .container {
        width: min(1160px, calc(100% - clamp(2rem, 6vw, 5rem)));
        margin: 0 auto;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 20;
        border-bottom: 1px solid var(--line);
        background: rgba(244, 247, 242, 0.88);
        backdrop-filter: blur(18px);
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 72px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--ink);
        font-weight: 800;
      }

      .brand-mark {
        display: grid;
        place-items: center;
        width: 38px;
        height: 38px;
        border: 1px solid rgba(17, 26, 23, 0.14);
        border-radius: 10px;
        background: var(--ink);
        color: #d8ebe6;
        font-family: var(--font-mono);
        font-size: 0.84rem;
        box-shadow: inset 0 -10px 18px rgba(47, 117, 107, 0.28);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 0.6rem 0.75rem;
        border-radius: var(--radius);
        transition: color 180ms ease, background 180ms ease;
      }

      .nav-link:hover,
      .nav-link[aria-current="page"] {
        background: rgba(47, 117, 107, 0.09);
        color: var(--ink);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.72rem 1rem;
        border: 1px solid var(--line-strong);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.56);
        color: var(--ink);
        font-weight: 750;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease, box-shadow 180ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
        border-color: rgba(47, 117, 107, 0.46);
        background: #fff;
        box-shadow: 0 10px 22px rgba(28, 61, 53, 0.1);
      }

      .button:active {
        transform: translateY(0);
      }

      .button.primary {
        border-color: var(--accent);
        background: var(--accent);
        color: #fff;
        box-shadow: 0 14px 32px rgba(47, 117, 107, 0.18);
      }

      .button.primary:hover {
        background: var(--accent-strong);
      }

      .eyebrow {
        margin: 0;
        color: var(--accent-strong);
        font-size: 0.94rem;
        font-style: italic;
        font-weight: 750;
      }

      .card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.76);
        box-shadow: var(--shadow);
      }

      .section {
        padding: 5.25rem 0;
      }

      .section h2 {
        margin: 0.65rem 0 1rem;
        max-width: 820px;
        color: var(--ink);
        font-size: 3.25rem;
        line-height: 0.98;
        letter-spacing: 0;
        text-wrap: balance;
      }

      .section p {
        max-width: 68ch;
        color: var(--muted);
        line-height: 1.72;
      }

      .footer {
        border-top: 1px solid var(--line);
        background: rgba(237, 243, 236, 0.62);
        color: var(--muted);
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.4rem 0;
        font-size: 0.94rem;
      }

      .footer-links {
        display: flex;
        gap: 1rem;
      }

      .footer a {
        color: var(--ink);
        font-weight: 700;
      }

      @media (max-width: 820px) {
        .nav-inner {
          align-items: flex-start;
          flex-direction: column;
          gap: 0.75rem;
          padding: 0.85rem 0;
        }

        .nav-links {
          width: 100%;
          flex-wrap: wrap;
        }

        .nav-link {
          padding-inline: 0.65rem;
        }

        .nav-links .hide-sm {
          display: none;
        }

        .section {
          padding: 3.75rem 0;
        }

        .section h2 {
          font-size: 2.35rem;
        }

        .footer-inner {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <nav class="nav" aria-label="Primary">
      <div class="container nav-inner">
        <a class="brand" href="/" aria-label="PGSandbox MCP home">
          <span class="brand-mark">pg</span>
          <span>PGSandbox MCP</span>
        </a>
        <div class="nav-links">
          <a class="nav-link" href="/#start">Start</a>
          <a class="nav-link" href="/docs/" aria-current={isDocs ? 'page' : undefined}>Docs</a>
          <a class="nav-link hide-sm" href="/docs/mcp-tools/">MCP tools</a>
          <a class="button" href="https://github.com/LVTD-LLC/pgsandbox-mcp">GitHub</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="footer">
      <div class="container footer-inner">
        <span>Built for agents that need real Postgres without shared-database drift.</span>
        <div class="footer-links">
          <a href="/docs/install/">Install</a>
          <a href="https://github.com/LVTD-LLC/pgsandbox-mcp/blob/main/LICENSE">MIT license</a>
        </div>
      </div>
    </footer>
  </body>
</html>
