{
  "name": "pgsandbox-mcp",
  "version": "0.1.0",
  "description": "MCP server for disposable Postgres sandboxes.",
  "private": true,
  "scripts": {
    "build": "cargo build --release",
    "check": "cargo check",
    "package:homebrew": "cargo build --release && sh scripts/package-homebrew.sh",
    "test": "cargo test",
    "typecheck": "cargo check",
    "start": "cargo run --",
    "site:build": "npm --prefix site run build"
  },
  "keywords": [
    "mcp",
    "postgres",
    "postgresql",
    "agents",
    "sandbox"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LVTD-LLC/pgsandbox-mcp.git"
  },
  "license": "MIT"
}
